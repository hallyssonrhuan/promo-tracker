# Telegram bot — pegar via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=
# chat_ids pra receber notif. Pode ser:
#   - 1 valor:  TELEGRAM_CHAT_ID=7765605626
#   - varios:   TELEGRAM_CHAT_ID=7765605626,123456789
#   - grupo/canal (id negativo): TELEGRAM_CHAT_ID=-1001234567890
# Cada pessoa pega o id dela em @userinfobot DEPOIS de iniciar conversa com seu bot.
TELEGRAM_CHAT_ID=

# WhatsApp via CallMeBot — opcional. Se preenchido, notif vai pros DOIS canais.
# Setup: 1) Adicione +34 644 51 95 23 nos contatos como "CallMeBot"
#        2) Mande pelo WhatsApp: "I allow callmebot to send me messages"
#        3) Espere a resposta com sua API key (~2min)
# Telefone com codigo do pais SEM '+', ex: 5511999999999
WHATSAPP_PHONE=
WHATSAPP_APIKEY=

# App
HTTP_CACHE_DIR=./data/http_cache
USER_AGENT=PromoTracker/0.1 (uso pessoal)

# Onde fica o state.json (versionado no repo). Em prod (GH Actions) usa o default.
# Local pra teste, pode usar outro caminho temporario.
STATE_PATH=data/state.json

# Limites
MIN_DESCONTO_PCT=15
MAX_NOTIFICACOES_POR_JOB=10
THROTTLE_SEGUNDOS=3

# Modo dev: cache HTTP de 6h pra coletas locais (em prod desliga).
DEV_MODE=false
